SQL {
  Statement
    = SelectStatement ";"?
    | InsertStatement ";"?
    | UpdateStatement ";"?

  // --- INSERT ---

  InsertStatement
    = insert into TableName "(" NonemptyListOf<identifier, ","> ")" values NonemptyListOf<ValuesRow, ",">  -- withCols
    | insert into TableName values NonemptyListOf<ValuesRow, ",">                                          -- noCols

  ValuesRow = "(" NonemptyListOf<WhereValue, ","> ")"

  // --- UPDATE ---

  UpdateStatement = update TableName set NonemptyListOf<Assignment, ","> WhereClause?

  Assignment = identifier "=" WhereValue

  SelectStatement
    = select DistinctClause? ColumnList from TableRef JoinClause* WhereClause? GroupByClause? HavingClause? OrderByClause? LimitClause? OffsetClause?

  // --- PostgreSQL: DISTINCT ON ---
  DistinctClause
    = distinct on "(" NonemptyListOf<WhereValue, ","> ")"  -- on
    | distinct                                              -- plain

  Distinct = distinct

  // --- Columns ---

  ColumnList = NonemptyListOf<ColumnEntry, ",">

  ColumnEntry
    = ColumnExpr as identifier  -- aliased
    | ColumnExpr                -- plain

  ColumnExpr
    = qualifiedWildcard   -- qualifiedWild
    | wildcard            -- wild
    | WhereValue          -- expr

  FuncCall = identifier "(" FuncArgs ")"

  FuncArgs
    = distinct FuncArgList  -- distinct
    | FuncArgList           -- plain
    | wildcard              -- wildcard
    | /* empty */           -- empty

  FuncArgList = NonemptyListOf<WhereValue, ",">

  qualifiedWildcard = identifier "." "*"
  wildcard          = "*"

  // --- FROM ---

  TableRef
    = TableName as identifier  -- aliased
    | TableName identifier     -- implicitAlias
    | TableName                -- plain

  TableName
    = identifier "." identifier  -- qualified
    | identifier                 -- simple

  // --- JOIN ---

  JoinClause
    = JoinType join TableRef JoinCondition  -- typed
    | join TableRef JoinCondition           -- bare
    | cross join TableRef                   -- cross
    | natural join TableRef                 -- natural

  JoinType
    = inner outer              -- innerOuter
    | inner                    -- inner
    | left outer               -- leftOuter
    | left                     -- left
    | right outer              -- rightOuter
    | right                    -- right
    | full outer               -- fullOuter
    | full                     -- full

  JoinCondition
    = on WhereExpr             -- on
    | using "(" NonemptyListOf<identifier, ","> ")"  -- using

  // --- WHERE ---

  WhereClause = where WhereExpr

  WhereExpr = WhereOrExpr

  WhereOrExpr
    = WhereOrExpr or WhereAndExpr  -- or
    | WhereAndExpr

  WhereAndExpr
    = WhereAndExpr and WherePrimary  -- and
    | WherePrimary

  WherePrimary
    = "(" WhereExpr ")"    -- paren
    | not WherePrimary     -- not
    | WhereComparison
    | WhereValue           -- value

  WhereComparison
    = WhereValue compOp WhereValue              -- compare
    | WhereValue is not null                    -- isNotNull
    | WhereValue is null                        -- isNull
    | WhereValue is not boolLiteral             -- isNotBool
    | WhereValue is boolLiteral                 -- isBool
    | WhereValue is unknown                     -- isUnknown
    | WhereValue is not unknown                 -- isNotUnknown
    | WhereValue not between WhereValue and WhereValue  -- notBetween
    | WhereValue between WhereValue and WhereValue      -- between
    | WhereValue not in "(" NonemptyListOf<WhereValue, ","> ")"  -- notIn
    | WhereValue in "(" NonemptyListOf<WhereValue, ","> ")"      -- in
    | WhereValue not like WhereValue            -- notLike
    | WhereValue like WhereValue                -- like
    | WhereValue not ilike WhereValue           -- notIlike  // PostgreSQL: case-insensitive LIKE
    | WhereValue ilike WhereValue               -- ilike     // PostgreSQL: case-insensitive LIKE
    | WhereValue tsMatchOp WhereValue           -- tsMatch   // PostgreSQL: text search match


  compOp = "<>" | "!=" | "<=" | ">=" | "<" | ">" | "="

  // --- PostgreSQL: text search ---
  tsMatchOp = "@@"

  // --- PostgreSQL: JSONB operators ---
  jsonbOp = "->>" | "->" | "#>>" | "#>" | "?|" | "?&" | "?" | "@>"

  // --- pgvector: distance operators ---
  pgvectorOp = "<->" | "<#>" | "<=>" | "<+>" | "<~>" | "<%>"

  // Expression hierarchy (lowest to highest precedence)
  WhereValue = AddExpr

  AddExpr
    = AddExpr "+" MulExpr   -- add
    | AddExpr "-" MulExpr   -- sub
    | AddExpr "||" MulExpr  -- concat
    | MulExpr

  MulExpr
    = MulExpr "*" ExtOpExpr  -- mul
    | MulExpr "/" ExtOpExpr  -- div
    | MulExpr "%" ExtOpExpr  -- mod
    | ExtOpExpr

  // --- PostgreSQL JSONB / pgvector extension operators ---
  ExtOpExpr
    = ExtOpExpr jsonbOp UnaryExpr     -- jsonb
    | ExtOpExpr pgvectorOp UnaryExpr  -- pgvector
    | UnaryExpr

  UnaryExpr
    = "-" PostfixExpr  -- neg
    | PostfixExpr

  // --- PostgreSQL: cast shorthand (expr::type) ---
  PostfixExpr
    = PostfixExpr "::" TypeName  -- castShorthand
    | AtomExpr

  AtomExpr
    = CaseExpr               -- case
    | CastExpr               -- cast
    | FuncCall               -- func
    | "(" WhereValue ")"     -- paren
    | stringLiteral          -- string
    | floatLiteral           -- float
    | integer                -- integer
    | boolLiteral            -- bool
    | null                   -- null
    | ColumnRef              -- columnRef

  CaseExpr
    = case WhereValue SimpleWhenClause+ ElseClause? end_kw  -- simple
    | case SearchedWhenClause+ ElseClause? end_kw           -- searched

  SimpleWhenClause   = when WhereValue then WhereValue
  SearchedWhenClause = when WhereExpr  then WhereValue
  ElseClause = else WhereValue

  CastExpr = cast "(" WhereValue as TypeName ")"

  TypeName = identifier ("(" integer ("," integer)? ")")? ("[]")*

  ColumnRef
    = identifier "." identifier  -- qualified
    | identifier                 -- simple

  stringLiteral = "'" (~"'" any)* "'"
  floatLiteral  = digit+ "." digit+

  true_kw  = caseInsensitive<"true">  ~identPart
  false_kw = caseInsensitive<"false"> ~identPart
  boolLiteral = (true_kw | false_kw)

  // --- GROUP BY / HAVING ---

  GroupByClause = group by NonemptyListOf<WhereValue, ",">

  HavingClause = having WhereExpr

  // --- ORDER BY ---

  OrderByClause = order by NonemptyListOf<OrderByItem, ",">

  OrderByItem = WhereValue OrderDirection? NullsOrder?

  OrderDirection
    = asc   -- asc
    | desc  -- desc

  NullsOrder
    = nulls first  -- first
    | nulls last   -- last

  // --- LIMIT / OFFSET ---

  LimitClause = limit integer
  OffsetClause = offset integer

  // --- Terminals ---

  identifier = quotedIdentifier | bareIdentifier
  bareIdentifier = ~keyword letter (alnum | "_")*
  quotedIdentifier = "\"" (~"\"" any)* "\""
  integer    = digit+

  // --- Keywords (case-insensitive) ---

  select = caseInsensitive<"select"> ~identPart
  from   = caseInsensitive<"from">   ~identPart
  as     = caseInsensitive<"as">     ~identPart
  where  = caseInsensitive<"where">  ~identPart
  and    = caseInsensitive<"and">    ~identPart
  or     = caseInsensitive<"or">     ~identPart
  limit  = caseInsensitive<"limit">  ~identPart
  not     = caseInsensitive<"not">     ~identPart
  null    = caseInsensitive<"null">    ~identPart
  is      = caseInsensitive<"is">      ~identPart
  join    = caseInsensitive<"join">    ~identPart
  inner   = caseInsensitive<"inner">   ~identPart
  left    = caseInsensitive<"left">    ~identPart
  right   = caseInsensitive<"right">   ~identPart
  full    = caseInsensitive<"full">    ~identPart
  outer   = caseInsensitive<"outer">   ~identPart
  cross   = caseInsensitive<"cross">   ~identPart
  natural = caseInsensitive<"natural"> ~identPart
  on      = caseInsensitive<"on">      ~identPart
  using   = caseInsensitive<"using">   ~identPart
  order   = caseInsensitive<"order">   ~identPart
  by      = caseInsensitive<"by">      ~identPart
  group    = caseInsensitive<"group">    ~identPart
  having   = caseInsensitive<"having">  ~identPart
  distinct = caseInsensitive<"distinct"> ~identPart
  asc     = caseInsensitive<"asc">     ~identPart
  desc    = caseInsensitive<"desc">    ~identPart
  nulls   = caseInsensitive<"nulls">   ~identPart
  first   = caseInsensitive<"first">   ~identPart
  last    = caseInsensitive<"last">    ~identPart
  offset   = caseInsensitive<"offset">   ~identPart
  between  = caseInsensitive<"between">  ~identPart
  in       = caseInsensitive<"in">       ~identPart
  like     = caseInsensitive<"like">     ~identPart
  ilike    = caseInsensitive<"ilike">    ~identPart  // PostgreSQL
  unknown  = caseInsensitive<"unknown">  ~identPart
  case     = caseInsensitive<"case">     ~identPart
  when     = caseInsensitive<"when">     ~identPart
  then     = caseInsensitive<"then">     ~identPart
  else     = caseInsensitive<"else">     ~identPart
  end_kw   = caseInsensitive<"end">      ~identPart
  cast     = caseInsensitive<"cast">     ~identPart
  insert   = caseInsensitive<"insert">   ~identPart
  into     = caseInsensitive<"into">     ~identPart
  values   = caseInsensitive<"values">   ~identPart
  update   = caseInsensitive<"update">   ~identPart
  set      = caseInsensitive<"set">      ~identPart

  keyword = select | from | as | where | and | or | limit | not | null | is
          | join | inner | left | right | full | outer | cross | natural | on | using
          | order | by | asc | desc | nulls | first | last | offset | group | having | distinct
          | between | in | like | ilike | unknown
          | case | when | then | else | end_kw | cast
          | insert | into | values | update | set
          | true_kw | false_kw
  identPart = alnum | "_"

  // --- Comments & whitespace ---

  space += lineComment | blockComment
  lineComment  = "--" (~"\n" any)*
  blockComment = "/*" (~"*/" any)* "*/"
}
